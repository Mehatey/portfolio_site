_site
.bundle

# ─── Block heavy media globally ───
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.glb
*.gltf
*.fbx
*.zip
*.tar.gz

# ─── Block assets/video by default, allow specific homepage/loader files ───
assets/video/*
!assets/video/cube_gettingup.mp4
!assets/video/loading-ani.mp4
!assets/video/sid_intro.mp4
!assets/video/sid_pixelated.mp4
!assets/video/sid_sitting.mp4

# ─── Allow video/mov inside project asset folders ───
!1.met/**/*.mp4
!1.met/**/*.mov
!2.cube/**/*.mp4
!2.cube/**/*.mov
!2.ai-self/**/*.mp4
!4.mandala/**/*.mp4
!4.mandala/**/*.mov
!5.bb/**/*.mp4
!5.mool/**/*.mp4
!6.mindu/**/*.mp4
!7.naavo/**/*.mp4
!8.shotoniphone/**/*.mp4
!9.aananda/**/*.mp4
!10.alpha/**/*.mp4
!11.illu/**/*.mp4

# ─── Allow play page assets (videos in masonry + spiral hero) ───
!play/assets/*.mp4
!play/assets/*.gif

# ─── Standard ignores ───
.DS_Store
.idea
.jekyll-cache
.jekyll-metadata
.ruby-version
.sass-cache
.tweet-cache
.venv
assets/libs/
assets/rendercv/rendercv_output/*.typ
Gemfile.lock
node_modules/
vendor2.cube/
